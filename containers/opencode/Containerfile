#FROM node:24.15.0-bookworm
FROM registry.redhat.io/ubi10/nodejs-24:latest

ARG TARGETARCH
ARG OPENCODE_FORK_REPO=agent-fox-dev/opencode

ENV OPENCODE_PORT=4096 \
    OPENCODE_HOSTNAME=0.0.0.0 \
    OPENCODE_MODE=web

RUN ARCH=$(echo ${TARGETARCH} | sed 's/amd64/x64/') && \
    echo "Building for TARGETARCH=${TARGETARCH} (release arch: ${ARCH})" && \
    RELEASE_TAG=$(curl -fsSL "https://api.github.com/repos/${OPENCODE_FORK_REPO}/releases/latest" | grep '"tag_name"' | cut -d'"' -f4) && \
    FILENAME="opencode-linux-${ARCH}.tar.gz" && \
    DOWNLOAD_URL="https://github.com/${OPENCODE_FORK_REPO}/releases/download/${RELEASE_TAG}/${FILENAME}" && \
    echo "Downloading opencode from ${DOWNLOAD_URL}" && \
    curl -fsSL -o /tmp/opencode.tar.gz "${DOWNLOAD_URL}" && \
    mkdir -p ${APP_ROOT}/bin /tmp/opencode-extract && \
    tar xzf /tmp/opencode.tar.gz -C /tmp/opencode-extract && \
    mv /tmp/opencode-extract/bin/opencode ${APP_ROOT}/bin/opencode && \
    chmod 755 ${APP_ROOT}/bin/opencode && \
    rm -rf /tmp/opencode.tar.gz /tmp/opencode-extract

COPY ./containers/opencode/run /usr/local/bin/run

ENV PATH=${APP_ROOT}/bin:$PATH \
    OPENCODE_DB=${APP_ROOT}/data/opencode.db \
    XDG_DATA_HOME=${APP_ROOT}/data \
    XDG_CONFIG_HOME=${APP_ROOT}/config \
    XDG_STATE_HOME=${APP_ROOT}/state \
    XDG_CACHE_HOME=${APP_ROOT}/cache

RUN opencode --help

RUN mkdir -p ${APP_ROOT}/data && \
    mkdir -p ${APP_ROOT}/config && \
    mkdir -p ${APP_ROOT}/state && \
    mkdir -p ${APP_ROOT}/cache && \
    chown -R 1001:0 ${APP_ROOT} && chmod -R ug+rwx ${APP_ROOT}

# set working directory
WORKDIR ${APP_ROOT}/src

# set the user to 1001
USER 1001
EXPOSE ${OPENCODE_PORT}
CMD ["/usr/local/bin/run"]